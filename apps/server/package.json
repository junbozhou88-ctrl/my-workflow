    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260616.1",
    "@my-workflow-lambda/config": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:",
    "wrangler": "^4.100.0"
  }
}
